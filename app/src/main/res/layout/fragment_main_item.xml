<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/main_item_icon_card"
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            android:tint="?android:attr/textColorPrimary"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/main_item_image"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_sms_gray_24dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/main_item_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ntfy.sh/example"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginStart="14dp"
            app:layout_constraintStart_toEndOf="@id/main_item_icon_card"
            app:layout_constraintTop_toTopOf="@id/main_item_icon_card"
            app:layout_constraintEnd_toStartOf="@id/main_item_date"/>

        <TextView
            android:id="@+id/main_item_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0 notificaciones"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toEndOf="@id/main_item_icon_card"
            app:layout_constraintTop_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toStartOf="@id/main_item_date"/>

        <TextView
            android:id="@+id/main_item_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20/2/2026"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toTopOf="@id/main_item_icon_card"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/main_item_connection_error_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:srcCompat="@drawable/ic_warning_amber_24dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/main_item_notification_disabled_until_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:srcCompat="@drawable/ic_notifications_off_time_gray_outline_24dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/main_item_notification_disabled_forever_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:srcCompat="@drawable/ic_notifications_off_gray_outline_24dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/main_item_instant_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:srcCompat="@drawable/ic_bolt_gray_24dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/main_item_new"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="24dp"
            android:minHeight="24dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/main_item_date"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>